# Anker Cloud API Credentials
# Use your Anker account email/password (same as the iOS app)
# NOTE: Only one active session per account at a time. If you open the iOS app
# while this script is running, the script's session may be invalidated.
ANKER_EMAIL=your_email@example.com
ANKER_PASSWORD=your_password

# Country ID (US, DE, GB, etc.)
ANKER_COUNTRY=US

# F3800 Device Serial Number (found in Anker app → Device Settings → About)
# Format: A1783xxxxxxxx or A1790xxxxxxxx
DEVICE_SN=

# F3800 Local IP Address (for future Modbus TCP support)
F3800_IP=10.0.0.52

# Connection mode: "mqtt" (cloud) or "modbus" (local, requires enabling in app)
CONNECTION_MODE=mqtt

# Data logging
LOG_DIR=./data
LOG_TO_CSV=true
LOG_TO_SQLITE=true

# Polling interval in seconds — how often to request fresh data from the F3800
# Default: 600 (10 minutes). Also used by Modbus mode.
POLL_INTERVAL=600

# Temperature unit: "F" for Fahrenheit, "C" for Celsius
# Can also be toggled at runtime with the [t] menu command
TEMP_UNIT=F

# Database write interval in seconds — minimum time between SQLite/CSV writes.
# The display updates on every MQTT event (real-time), but the database only
# records a snapshot at this interval. Default: 300 (5 min = 12 pts/hr).
# CLI: --db-interval 5 (in minutes)
DB_WRITE_INTERVAL=300

# Database sleep timeout in seconds — if PV1, PV2, and AC output are all zero
# for this long, stop writing to the database ("sleep mode"). The first data
# point with any PV/AC activity resumes writes immediately.
# Default: 1800 (30 min). Set to 0 to disable sleep mode.
# CLI: --sleep-timeout 30 (in minutes)
DB_SLEEP_TIMEOUT=1800

# Timezone offset from UTC (hours). PDT = -7, PST = -8
TZ_OFFSET=-7

# Google Sheets spreadsheet ID for daily summary export
# Find it in the Sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# Leave empty to skip Sheets upload. Used by daily_summary.py.
GOOGLE_SHEET_ID=
